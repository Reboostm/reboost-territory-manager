# ═══════════════════════════════════════════════════════════════════
#  Reboost SEO Audit — Environment Variables
#  Copy this file → .env.local for local dev
#  Add ALL of these to Vercel: Project → Settings → Environment Variables
# ═══════════════════════════════════════════════════════════════════

# ── Firebase (project: seo-audit-2060f) ─────────────────────────
#  Get these from: Firebase Console → Project Settings → Your Apps
#  → Add Web App (or click the existing one) → SDK Setup → Config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=seo-audit-2060f.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=seo-audit-2060f
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=seo-audit-2060f.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Google APIs ──────────────────────────────────────────────────
#  One key covers: Places API, PageSpeed Insights, Maps Embed API
#  Get key: console.cloud.google.com → APIs & Services → Credentials → Create Key
#  Enable these 3 APIs in the same console
GOOGLE_PLACES_API_KEY=

# ── SerpAPI ──────────────────────────────────────────────────────
#  Powers real Map Pack ranking data (what position you show up at)
#  Get key: serpapi.com → Dashboard
#  $50/mo Hobby plan = ~100 audits/mo
SERP_API_KEY=

# ── GoHighLevel ──────────────────────────────────────────────────
#  Pushes every audit lead directly into GHL as a contact
#  Get key: GHL → Settings → API Keys → + Create Key (Location type)
GHL_API_KEY=

# ── Email — Resend ───────────────────────────────────────────────
#  Sends the branded audit report email to each lead
#  Get key: resend.com → API Keys → + Create API Key
#  Verify your sending domain at resend.com → Domains first
RESEND_API_KEY=
FROM_EMAIL=reports@yourdomain.com

# ── App Config ───────────────────────────────────────────────────
#  Your live Vercel URL (used in email links & GHL report URL)
NEXT_PUBLIC_BASE_URL=https://seo-audit-kappa.vercel.app

#  Calendly or cal.com link for "Book a Call" CTA on the report
NEXT_PUBLIC_CALENDAR_LINK=https://calendly.com/yourlink

#  Admin dashboard password — CHANGE THIS before going live
ADMIN_PASSWORD=reboost2024
