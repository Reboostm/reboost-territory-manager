# ─────────────────────────────────────────────────────────────────
# Reboost SEO Audit Tool — Environment Variables
# Copy this file to .env.local and fill in your values
# ─────────────────────────────────────────────────────────────────

# ── Google APIs ──────────────────────────────────────────────────
# Used for: Google Places (find business), Maps embed, PageSpeed
# Get key: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Places API, Maps Embed API, PageSpeed Insights API
GOOGLE_PLACES_API_KEY=your_google_api_key_here

# ── SerpAPI ──────────────────────────────────────────────────────
# Used for: Google Map Pack ranking data
# Get key: https://serpapi.com → Dashboard
# Plans start at ~$50/mo. Run 100 audits/mo on Hobby plan.
SERP_API_KEY=your_serpapi_key_here

# ── GoHighLevel (GHL) ────────────────────────────────────────────
# Used for: Pushing leads into your CRM + triggering automations
# Get key: GHL → Settings → API Keys → Create Key (Location API Key)
GHL_API_KEY=your_ghl_api_key_here

# ── Email (Resend) ───────────────────────────────────────────────
# Used for: Sending audit report emails to leads
# Get key: https://resend.com → API Keys
RESEND_API_KEY=your_resend_api_key_here
FROM_EMAIL=reports@yourdomain.com

# ── App Settings ─────────────────────────────────────────────────
# Your deployed URL (used in report email links)
NEXT_PUBLIC_BASE_URL=https://yourdomain.com

# Calendar link for "Book a Call" CTA buttons
NEXT_PUBLIC_CALENDAR_LINK=https://calendly.com/yourlink

# Admin dashboard password (change this!)
ADMIN_PASSWORD=reboost2024
